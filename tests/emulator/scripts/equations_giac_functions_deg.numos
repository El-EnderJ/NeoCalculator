# GIAC-D01: DEG policy is converted explicitly before the Giac solve.
wait 200
set_angle_mode deg
open_app Equations
wait 60
key ENTER
key ENTER
key sin
key x
key RIGHT
key =
key 1
key FRAC
key 2
key RIGHT
key ENTER
key DOWN
key DOWN
key ENTER
wait 180
assert_angle_mode deg
assert_equations_engine giac
assert_equations_status ok
assert_equations_solution_count 2
assert_equations_solution_exact x 0 30
assert_equations_solution_exact x 1 150
assert_equations_result_kind structured
assert_equations_tutor_status unavailable
