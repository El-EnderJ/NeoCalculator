open_app Equations
wait 60
key ENTER
key ENTER
key x
key +
key y
key =
key 1
key ENTER
key DOWN
key ENTER
key ENTER
key x
key +
key y
key =
key 2
key ENTER
key DOWN
key DOWN
key ENTER
wait 160
