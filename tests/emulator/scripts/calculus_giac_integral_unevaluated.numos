# GIAC-E01: a valid unevaluated Giac integral remains an exact text result.
wait 200
open_app Calculus
wait 60
key GRAPH
key sin
key sin
key x
key RIGHT
key RIGHT
key ENTER
wait 180
assert_calculus_engine giac
assert_calculus_operation integrate_indefinite
assert_calculus_status ok
assert_calculus_result_kind text_fallback
assert_calculus_result_exact integrate(sin(sin(x)),x)
assert_calculus_tutor_status unavailable
