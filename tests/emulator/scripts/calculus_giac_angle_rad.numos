# GIAC-E01: RAD mode stays the AngleModeRuntime source of truth.
wait 200
open_app Calculus
wait 60
set_angle_mode rad
assert_angle_mode rad
key sin
key x
key RIGHT
key ENTER
wait 120
assert_calculus_engine giac
assert_calculus_status ok
assert_calculus_result_kind structured
assert_calculus_result_exact cos(x)
assert_calculus_tutor_status agreed
