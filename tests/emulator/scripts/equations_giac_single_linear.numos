# GIAC-D01: normal Equations builds use Giac for the displayed answer.
# Assert-only: no screenshots or golden changes.

wait 200
open_app Equations
wait 60
assert_app Equations

# Add an empty row, author 2*x+4=0, save it, then choose Solve.
key ENTER
key ENTER
key 2
key *
key x
key +
key 4
key =
key 0
key ENTER
key DOWN
key DOWN
key ENTER
wait 100

assert_equations_engine giac
assert_equations_status ok
assert_equations_solution_count 1
assert_equations_solution_exact x 0 -2
assert_equations_solution_near x 0 -2 0.0000001
assert_equations_result_kind structured
assert_equations_tutor_status agreed
