# GIAC-E01: a Giac undefined result never promotes a native answer.
wait 200
open_app Calculus
wait 60
key GRAPH
key 0
key FRAC
key 0
key RIGHT
key ENTER
wait 120
assert_calculus_engine giac
assert_calculus_operation integrate_indefinite
assert_calculus_status undefined
assert_calculus_result_kind none
assert_calculus_tutor_status unavailable
