# GIAC-D01: rejected input must never invoke the legacy answer engine.
wait 200
open_app Equations
wait 60
key ENTER
key ENTER
key x
key =
key ENTER
key DOWN
key DOWN
key ENTER
wait 120
assert_equations_engine giac
assert_equations_status parse_error
assert_equations_solution_count 0
assert_equations_result_kind none
assert_equations_tutor_status unavailable
