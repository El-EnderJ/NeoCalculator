# calc_error_div_by_zero.numos — evaluate 1/0 under the GIAC-B01 engine.
#
# INTENDED SEMANTIC CHANGE (GIAC-B01): the legacy evaluator returned
# "Math ERROR" for 1/0; Giac's honest semantics are 1/0 == infinity ("oo"),
# an OK result presented through the text-fallback tier. The old
# assert_error expectation was legacy-specific and is superseded here;
# 0/0 (a genuine undef) keeps the error contract and is covered by
# calc_semantic_giac_infinity_undef.numos.
#
# Phase 8B lineage; NO screenshot, NO golden.
#
# Run:
#   program --headless --deterministic --script tests/emulator/scripts/calc_error_div_by_zero.numos \
#           --frames 1400 --quiet
# Exit codes: 0 ok · 2 script/parse error · 3 screenshot write error · 4 assertion failure.

log "calc_error_div_by_zero: waiting for launcher"
wait 200

# Open Calculation (appId 0 — dead-center-visible on power-on).
key ENTER
wait 60

# Build the fraction 1/0 and evaluate it.
key 1
key FRAC
key 0
key RIGHT
key ENTER
wait 120

# GIAC-B01 semantics: 1/0 is Giac infinity — OK status, text fallback "oo".
assert_app Calculation
assert_no_error
assert_calc_engine giac
assert_calc_status ok
assert_calc_result_kind text_fallback
assert_calc_exact oo
log "calc_error_div_by_zero: assertions passed (1/0 == oo, honest Giac semantics)"
