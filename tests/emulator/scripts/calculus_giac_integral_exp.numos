# GIAC-E01: e^x integrates exactly to exp(x).
wait 200
open_app Calculus
wait 60
key GRAPH
key e
key ^
key x
key ENTER
wait 120
assert_calculus_engine giac
assert_calculus_operation integrate_indefinite
assert_calculus_status ok
assert_calculus_result_kind structured
assert_calculus_result_exact exp(x)
assert_calculus_tutor_status unavailable
