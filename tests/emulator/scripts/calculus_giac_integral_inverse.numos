# GIAC-E01: Giac preserves the real-domain antiderivative ln(abs(x)).
wait 200
open_app Calculus
wait 60
key GRAPH
key 1
key FRAC
key x
key RIGHT
key ENTER
wait 120
assert_calculus_engine giac
assert_calculus_operation integrate_indefinite
assert_calculus_status ok
assert_calculus_result_kind structured
assert_calculus_result_exact ln(abs(x))
assert_calculus_tutor_status unavailable
