# calc_semantic_giac_sqrt2.numos — GIAC-B01: sqrt(2) stays an exact radical
# (tier-1 ExactVal mirror: 1*sqrt(2)), rendered by the legacy radical path.
#
# Assert-only smoke: NO screenshot, NO golden.
# Run: program --headless --deterministic --script <this> --frames 1600 --quiet

log "calc_semantic_giac_sqrt2: waiting for launcher"
wait 200
open_app Calculation
wait 60

key sqrt
key 2
key RIGHT
key ENTER
wait 120

assert_app Calculation
assert_no_error
assert_calc_status ok
assert_calc_result_kind structured
assert_calc_exact sqrt(2)
log "calc_semantic_giac_sqrt2: PASS (sqrt(2) exact radical)"
