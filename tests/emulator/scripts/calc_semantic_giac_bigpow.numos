# calc_semantic_giac_bigpow.numos — GIAC-B01: 2^100 exceeds int64 and is
# presented through the STRUCTURED tier with all exact digits (never a lossy
# double reconstruction). The exact text is Giac's big integer.
#
# Assert-only smoke: NO screenshot, NO golden.
# Run: program --headless --deterministic --script <this> --frames 1600 --quiet

log "calc_semantic_giac_bigpow: waiting for launcher"
wait 200
open_app Calculation
wait 60

key 2
key pow
key 1
key 0
key 0
key RIGHT
key ENTER
wait 120

assert_app Calculation
assert_no_error
assert_calc_status ok
assert_calc_result_kind structured
assert_calc_exact 1267650600228229401496703205376
log "calc_semantic_giac_bigpow: PASS (2^100 exact big integer)"
