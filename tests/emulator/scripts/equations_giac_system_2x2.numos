# GIAC-D01: one Giac system call, exact values in UI variable order.
wait 200
open_app Equations
wait 60
key ENTER
key ENTER
key x
key +
key y
key =
key 3
key ENTER
key DOWN
key ENTER
key ENTER
key x
key -
key y
key =
key 1
key ENTER
key DOWN
key DOWN
key ENTER
wait 180
assert_equations_engine giac
assert_equations_status ok
assert_equations_solution_count 1
assert_equations_solution_exact x 0 2
assert_equations_solution_exact y 0 1
assert_equations_result_kind structured
assert_equations_tutor_status unavailable
