# GIAC-D01: product complex-root policy remains explicit.
wait 200
set_equations_complex_policy complex
open_app Equations
wait 60
key ENTER
key ENTER
key x
key ^
key 2
key RIGHT
key +
key 1
key =
key 0
key ENTER
key DOWN
key DOWN
key ENTER
wait 180
assert_equations_engine giac
assert_equations_status ok
assert_equations_solution_count 2
assert_equations_solution_exact x 0 -i
assert_equations_solution_exact x 1 i
assert_equations_result_kind structured
assert_equations_tutor_status unavailable

