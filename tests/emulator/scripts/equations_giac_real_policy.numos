# GIAC-D01: the same polynomial has no roots under real-only policy.
wait 200
set_equations_complex_policy real
open_app Equations
wait 60
key ENTER
key ENTER
key x
key ^
key 2
key RIGHT
key +
key 1
key =
key 0
key ENTER
key DOWN
key DOWN
key ENTER
wait 180
assert_equations_engine giac
assert_equations_status no_solution
assert_equations_solution_count 0
assert_equations_result_kind structured
assert_equations_tutor_status unavailable

