# calc_semantic_giac_exact_fraction.numos — GIAC-B01: 1/2 + 1/3 stays the
# exact fraction 5/6 through Giac (tier-1 ExactVal mirror, legacy rendering).
#
# Assert-only smoke: NO screenshot, NO golden.
# Run: program --headless --deterministic --script <this> --frames 1600 --quiet

log "calc_semantic_giac_exact_fraction: waiting for launcher"
wait 200
open_app Calculation
wait 60

key 1
key FRAC
key 2
key RIGHT
key +
key 1
key FRAC
key 3
key RIGHT
key ENTER
wait 120

assert_app Calculation
assert_no_error
assert_calc_engine giac
assert_calc_status ok
assert_calc_result_kind structured
assert_calc_exact 5/6
assert_result 5/6
log "calc_semantic_giac_exact_fraction: PASS (1/2+1/3 == 5/6)"
