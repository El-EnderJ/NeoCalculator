# GIAC-E01: explicit compile-time rollback retains the previous pipeline.
wait 200
open_app Calculus
wait 60
key x
key ^
key 2
key ENTER
wait 120
assert_calculus_engine legacy
assert_calculus_operation differentiate
assert_calculus_status ok
assert_calculus_result_kind structured
assert_calculus_result_exact 2*x
assert_calculus_tutor_status disabled
