# GIAC-D01: duplicate roots are normalized to one exact solution.
wait 200
open_app Equations
wait 60
key ENTER
key ENTER
key (
key x
key -
key 1
key RIGHT
key ^
key 2
key RIGHT
key =
key 0
key ENTER
key DOWN
key DOWN
key ENTER
wait 160
assert_equations_engine giac
assert_equations_status ok
assert_equations_solution_count 1
assert_equations_solution_exact x 0 1
assert_equations_result_kind structured
assert_equations_tutor_status agreed
